# Server Configuration
NODE_ENV=development          # production | development
PORT=5052                     # Server port (defaults to 3000)

# Database
DATABASE_URL=./firehose.db    # SQLite database path

# Optional: OAuth configuration
OAUTH_SERVER_URL=             # OAuth endpoint URL
JWT_SECRET=                   # Session signing secret (generate with: openssl rand -base64 32)

# Optional: Forge API (if using built-in Forge integration)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
